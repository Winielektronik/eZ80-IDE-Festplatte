                                ;------------------------
                                ;  C:\BIOSINT.MAC
                                ;  Winterhalter Z84C015 System
                                ;  Entwicklungssystem
                                ;------------------------
                                ; BIOS fuer HW-CPU
                                ; PROZESSOR Z84C015 von ZILOG
                                ; MIT 128K SRAM 32K EPROM, 2k I/O SRAM RTC =M48T02
                                ; FDC, IDE, ECB-BUS
                                ;
                                ; AUTOR: Hansjoerg Winterhalter
                                ; Vers. 1.0                           16.06.2003
                                ; SD-Karte 1.0                        19.11.2006
                                ; LW IDE-HD IDE CONTROLLER-KARTE      21.06.2009        
                                ; ERWEITERUNG FUER HDD LBA-MODE 16BIT 14.09.2016
                                ; NACHTRAG ERROR WRITE EXTERN         30.12.2016
                                ;
                                ; SD-KARTE ADRESSE IN BLOECKE AUFGETEILT NICHT MEHR SEQUENZIAL 30.05.2008
                                ; SEKTOR, TRACK AUS 16BIT UMSTELLEN    05.06.2016
                                ; MMC SEC/TRK BERECHNUNG LINEAR 1,2,3,4,5, AUFSTEIGEND 30.09.2017
                                ;------------------------
                                
  0000'                         ASEG
                                
                                .Z80
                                
                                ORG 0H
                                
                                ;DISPLAY EQU 1          ; 1= MIT LCD-DISPLAY
                                
  0000                          RAMSTART EQU 0000H
                                
                                ; SET CP/M LOW MEMORY DATA, VECTOR AND BUFFER ADDRESS
                                
  0003                          IOBYTE  EQU RAMSTART + 03H
  0004                          USRDRV  EQU RAMSTART + 04H
  0005                          BDOSEN  EQU RAMSTART + 05H
  005C                          TPAFCB  EQU RAMSTART + 5CH
  0080                          TPABUF  EQU RAMSTART + 80H
                                
  8000                          RAM     EQU RAMSTART + 8000H
                                
                                ;---------------------------
                                ; PERIPERIE I/O ADDRESS
                         C      INCLUDE Z84C15H.MAC
                         C      ;--------------------------
                         C      ; BIOS Hardware CS Adresse
                         C      ; Z84C15 PERIFERIE
                         C      ; 22.09.2018 Hansjoerg Winterhalter
                         C      ;
  0018                   C      SIOA    EQU 18H         ; SIOA DATA REGISTER (84C43)
                         C                              ; SIOA +1 CONTROLL REGISTER
  001A                   C      SIOB    EQU 1AH         ; SIOB DATA REGISTER (84C43)
                         C                              ; SIOB +1 CONTROLL REGISTER
  0010                   C      CTC0    EQU 10H         ; CTC    CH0 CONTROLL REGISTER (84C30)
  0011                   C      CTC1    EQU 11H         ; CTC +1 CH1 CONTROLL REGISTER (84C30)
        MACRO-80 3.43   27-Jul-81       PAGE    1-1


  0012                   C      CTC2    EQU 12H         ; CTC +2 CH2 CONTROLL REGISTER (84C30)
  0013                   C      CTC3    EQU 13H         ; CTC +3 CH3 CONTROLL REGISTER (84C30)
  001C                   C      PIOA    EQU 1CH         ; PIOA DATA REGISTER (84C20)
                         C                              ; PIOA +1 COMMAND REGISTER
  001E                   C      PIOB    EQU 1EH         ; PIOB DATA REGISTER (84C20)
                         C                              ; PIOB +1 COMMAND REGISTER
                         C      ;---------------
  00F0                   C      WDTMR   EQU 0F0H        ; MASTER REGISTER WATCH DOG TIMER
  00F1                   C      WDTCR   EQU 0F1H        ; CONTROLL REGISTER
  00F4                   C      DCI     EQU 0F4H        ; DAISY-CAINE-INTRRUPT
                         C      ;---------------
  00EE                   C      SCRP    EQU 0EEH        ; SYSTEM CONTROLL REGISTER POINTER
  00EF                   C      SCDP    EQU 0EFH        ; SYSTEM CONTROLL DATA PORT
                         C      ;---------------
                         C      ; I/O CONTROLL REGISTER ADDRESS
                         C      ; END
                         C      INCLUDE BIOSSEL.MAC
                         C      ;--------------------------
                         C      ; BIOS Hardware CS Adresse
                         C      ; IM SYSTEM HARDWARE
                         C      ;
  00F5                   C      LATCH   EQU 0F5H        ; I/O ADDRESS LATCH FOR A8-A15 EXTERN BUS
  0020                   C      SDC     EQU 20H         ; MMC KATE
  0060                   C      LCD     EQU 60H         ; LCD-DISPAY
  0080                   C      URCS    EQU 80H         ; MIT 2K SRAM A0-A4 PIOA A5-A7
                         C      
  0040                   C      EOFF    EQU 40H         ; EPROM AUS RAM <32K AKTIV
  0021                   C      RAMH    EQU 21H         ; BIT1,5 PIOA BANK1
  0000                   C      RAML    EQU 00H         ; BIT1,5 PIOA BANK0
                                ;---------------
  0020                          FDC     EQU 20H         ; SD-KARTE
  0000                          EON     EQU 0           ; BIT 6=0 PORT A EPROM EIN RAM <32K WRITE
                                ;RAMH    EQU 61H         ; BIT1,5 AN PIO A BANK 1 + EPROM AUS / INTERN
                                ;RAML    EQU 40H         ; BIT1,5 AN PIO A BANK 0 + EPROM AUS / INTERN
                                ;------------------------
  00F0                          IDE     EQU 0F0H        ; FESTPLATTE
  00F6                          IDEDOR  EQU IDE+6       ; DIGITAL OUTPUT REGISTER
  00F8                          IDEDAT  EQU IDE+8       ; DATA REGISTER
  00F9                          IDEERR  EQU IDE+9       ; ERROR REGISTER
  00FA                          IDESCNT EQU IDE+0AH     ; SEKTOR COUNT
  00FB                          IDESNUM EQU IDE+0BH     ; SEKTOR NUMBER
  00FC                          IDECLO  EQU IDE+0CH     ; CYLINDER LOW
  00FD                          IDECHI  EQU IDE+0DH     ; CYLINDER HIGH
  00FE                          IDESDH  EQU IDE+0EH     ; DRIVE AND HEAD
  00FF                          IDECMD  EQU IDE+0FH     ; COMMAND
  00FF                          IDESTAT EQU IDECMD      ; STATUS
                                
                                ;-------------------------
                                ; IDE COMMANDOS
                                
  0020                          CMD_READSEC     EQU 20H
  0030                          CMD_WRITESEC    EQU 30H
  0070                          CMD_SEEK        EQU 70H
  0090                          CMD_DIAGN       EQU 90H
  0091                          CMD_INITIA      EQU 91H
  00EC                          CMD_IDENT       EQU 0ECH
        MACRO-80 3.43   27-Jul-81       PAGE    1-2


                                ;-----------------------------
                                ; MMC INTERFACE INIT
                                
  0040                          GO_IDLE_STATE   EQU 40H
  0041                          SEND_OP_COND    EQU 41H
  0050                          SDBLOCK         EQU 50H
  0051                          READ_SINGLE_BLOCK       EQU 51H
  0058                          WRITE_BLOCK     EQU 58H
                                ;------------------------
                                ;    CTC-COMMANDOS
                                ;------------------------
                                
  0047                          BAUD1   EQU 47H         ; 9600
  0004                          TIME1   EQU 04H         ; TIME CONSTANTE
                                
  0047                          BAUD2   EQU 47H         ; TGOUT 1: 2
  0004                          TIME2   EQU 04H         ;
                                
  0047                          BAUD3   EQU 47H         ; TGOUT 1: 2
  0004                          TIME3   EQU 04H         ;
                                
  00C7                          BAUD4   EQU 0C7H        ; MIT INT /16, CLK = CLK-CPU
  000F                          TIME4   EQU 0FH         ; BAUD4 * 0FH
                                
  0015                          MSTIME  EQU 15H         ; CTC3 * MSTIME
                                
  0060                          EXOFF   EQU 60H         ; OFFSET SIO, CTC EXTEN
                                
                                ;------------------------
                                ;    SIO-COMMANDOS
                                ;------------------------
                                
  0018                          SIORES  EQU 18H         ; SIO RESET
  0004                          KANAL4  EQU 04H         ; REG 4
  0044                          REG4    EQU 44H         ; X16 CLOCK,8,SYNC
  0003                          KANAL3  EQU 03H         ; REG 3
  00C1                          REG3    EQU 0C1H        ; 8 BIT, RxENABLE
  0005                          KANAL5  EQU 05H         ; REG 5
  00EA                          REG5    EQU 0EAH        ; DTR, Tx8BIT, TxENABLE
  0001                          KANAL1  EQU 01H         ; REG 1
  0000                          REG1    EQU 00H         ; NO INT
  0000                          KANAL0  EQU 00H         ; REG 0
                                ;----------------
                                ; PORT A BIT 0 - 7 SELEKT
                                ;----------------
                                
  0007                          QA7     EQU 7H          ; IORQ =0 INT., 1= EXT.
  0006                          ELATCH  EQU 6H          ; EPROM=0, RAM=1
  0005                          TA16    EQU 5H          ; RAM 64K BANK 0=LOW, >64K 1=HIGH
  0004                          FREI    EQU 4H          ; FREI  DA KEIN -> SCSI RESRI
  0003                          RFDC    EQU 3H          ; FLOPPY RESET
  0002                          RT      EQU 2H          ; AN PAL PIN 9
  0001                          NC      EQU 1H          ; NC
  0000                          TAS     EQU 0H          ; ZU 64K BANKUNSCHALTUNG
                                
                                ;------------------------
        MACRO-80 3.43   27-Jul-81       PAGE    1-3


                                ;      START
                                ;------------------------
                                ; TESTPROGRAMM F]R 84C015 CPU
                                ;------------------------
                                
  0000    F3                            DI
  0001    C3 015C                       JP LOS
  0004    00                            NOP
                                ;---------------------------------
                                ; EIGENE BIOS SPRUNGTABELLE 0005H
                                
                                ;INCLUDE CONSOLE.MAC
                                
  0060                          SIOEX   EQU 60H         ; OFSET ZU SIO INTERN = EXTERN
                                
                                ;-----------------------------
                                ; SIOA, SIOB ADRESSE TASK HIGH
                                ; SIO A
                                
  0005    ED 73 FDA1            SIOX:   LD (STACK),SP
  0009    ED 5E                         IM 2
  000B    FB                            EI
                                        REPT 5
                                        NOP
                                        ENDM
  000C    00              +             NOP
  000D    00              +             NOP
  000E    00              +             NOP
  000F    00              +             NOP
  0010    00              +             NOP
  0011    F3                            DI
  0012    DD 2A FDA1                    LD IX,(STACK)
  0016    DD F9                         LD SP,IX
  0018    DB 1C                         IN A,(PIOA)
  001A    CB 6F                         BIT TA16,A          ; BANK0=LX, BANK1=HX
  001C    20 03                         JR NZ,SIOX1        ; EXTERN ->
  001E    0E 18                         LD C,SIOA          ; FUER INTERN
  0020    C9                            RET
                                ;------------------
                                
  0021    0E 78                 SIOX1:  LD C,SIOA+SIOEX    ; FUER EXTERN
  0023    18 1E                         JR SIOX2
                                        ;--------------
                                        ; SIO B
  0025    ED 73 FDA1            SIOY:   LD (STACK),SP
  0029    ED 5E                         IM 2
  002B    FB                            EI
                                        REPT 5
                                        NOP
                                        ENDM
  002C    00              +             NOP
  002D    00              +             NOP
  002E    00              +             NOP
  002F    00              +             NOP
  0030    00              +             NOP
  0031    F3                            DI
        MACRO-80 3.43   27-Jul-81       PAGE    1-4


  0032    DD 2A FDA1                    LD IX,(STACK)
  0036    DD F9                         LD SP,IX
  0038    DB 1C                         IN A,(PIOA)
  003A    CB 6F                         BIT TA16,A
  003C    20 03                         JR NZ,SIOY1        ; EXTERN ->
  003E    0E 1A                         LD C,SIOB          ; FUER INTERN
  0040    C9                            RET
                                        ;---------
                                        ; EXTERN UNSCHALTEN
  0041    0E 7A                 SIOY1:  LD C,SIOB+SIOEX    ; FUER EXTERN
  0043    CB FF                 SIOX2:  SET 7,A            ; SET EXTERN
  0045    D3 1C                         OUT (PIOA),A
  0047    3E 02                         LD A,02H           ; SIO KARTE 2
  0049    D3 F5                         OUT (LATCH),A
  004B    C9                            RET
                                ;-----------------------------
                                ; TX BUFFER LEER PR]FEN
                                ; ZEICHEN IN C AUSGEBEN
                                
  004C    C5                    OUT0:   PUSH BC
  004D    CD 0056                       CALL KEYRD
  0050    7B                            LD A,E
  0051    0D                            DEC C
  0052    ED 79                         OUT (C),A           ; ZEICHEN AUSGEBEN
  0054    C1                            POP BC
  0055    C9                            RET
                                ;--------------------------------
                                ; KEYREADY
                                
  0056    CD 0005               KEYRD:  CALL SIOX
  0059    0C                            INC C
  005A    3E 05                         LD A,KANAL5
  005C    ED 79                         OUT (C),A
  005E    3E EA                         LD A,REG5
  0060    CB BF                         RES 7,A             ; DTR LOW
  0062    ED 79                         OUT (C),A
                                ;----------------
                                ; PR]FE OB ZEICHEN ]BERTRAGEN UND BUFFER LEER IST
                                
  0064    ED 78                 TX2:    IN A,(C)
  0066    CB 57                         BIT 2,A             ; TRANSMISSION BUFFER EMPTY
  0068    28 FA                         JR Z,TX2
  006A    C9                            RET
                                ;--------------------------------
                                ; RX BUFFER LEER PR]FEN
                                
  006B    C5                    INP0:   PUSH BC
  006C    CD 0056               INP1:   CALL KEYRD
  006F    CB 47                         BIT 0,A         ; AUS TX2:
  0071    28 18                         JR Z,INP2       ; PRUEFE OB ZEICHEN DA ->NEIN
  0073    0D                            DEC C
  0074    ED 78                         IN A,(C)        ; SIOA ZEICHEN HOLEN
  0076    4F                            LD C,A
  0077    C5                            PUSH BC
  0078    CD 0005                       CALL SIOX
  007B    0C                            INC C
        MACRO-80 3.43   27-Jul-81       PAGE    1-5


  007C    3E 05                         LD A,KANAL5
  007E    ED 79                         OUT (C),A
  0080    3E EA                         LD A,REG5
  0082    CB BF                         RES 7,A         ; DTR HIGH
  0084    ED 79                         OUT (C),A
  0086    C1                            POP BC
  0087    79                            LD A,C
  0088    C1                            POP BC
  0089    4F                            LD C,A
  008A    C9                            RET
                                        ;----------
  008B    3E 05                 INP2:   LD A,KANAL5
  008D    ED 79                         OUT (C),A
  008F    3E EA                         LD A,REG5
  0091    CB FF                         SET 7,A             ; DTR HIGH
  0093    ED 79                         OUT (C),A
  0095    18 D5                         JR INP1
                                ;--------------------------------
                                ;  PR]FE OB TESTE GEDR]CKT
                                ;  JA: A=0FFH NEIN: A:00H
                                
  0097    C5                    PKEY:   PUSH BC
  0098    CD 0005                       CALL SIOX
  009B    0C                            INC C
  009C    06 04                         LD B,04
  009E    CD 0064               CONW:   CALL TX2
  00A1    F5                            PUSH AF
  00A2    3E 05                         LD A,KANAL5
  00A4    ED 79                         OUT (C),A
  00A6    3E EA                         LD A,REG5
  00A8    CB FF                         SET 7,A             ; DTR HIGH
  00AA    ED 79                         OUT (C),A
  00AC    F1                            POP AF
  00AD    CB 47                         BIT 0,A
  00AF    3E FF                         LD A,0FFH
  00B1    20 03                         JR NZ,CONW1             ; -> TASTE GEDRUECKT
  00B3    10 E9                         DJNZ CONW
  00B5    AF                            XOR A                   ; KEINE TASTE
  00B6    F5                    CONW1:  PUSH AF
  00B7    3E 05                         LD A,KANAL5
  00B9    ED 79                         OUT (C),A
  00BB    3E EA                         LD A,REG5
  00BD    CB BF                         RES 7,A             ; DTR HIGH
  00BF    ED 79                         OUT (C),A
  00C1    F1                            POP AF
  00C2    C1                            POP BC
  00C3    FE 00                         CP 0            ; AUS A
  00C5    4F                            LD C,A
  00C6    C9                            RET
                                
                                ;--------------------------------
                                ;  LIST DRUCKERPROGRAMM
                                ; GIBT ZEICHEN IN C AUF DRUCKER AUS
                                ; WENN NICHT BEREIT , ABBRUCH MIT TASTE
                                
  00C7    C5                    PRINT:  PUSH    BC
        MACRO-80 3.43   27-Jul-81       PAGE    1-6


  00C8    CD 00D7               LISTA:  CALL    W00
  00CB    C1                            POP BC
  00CC    41                            LD B,C                  ; C = ZEICHEN ZUM DRUCKEN
  00CD    C5                            PUSH BC
  00CE    CD 0025                       CALL    SIOY
  00D1    78                            LD      A,B
  00D2    ED 79                         OUT     (C),A           ; ZEICHEN DRUCKEN
  00D4    C1                            POP     BC
  00D5    AF                            XOR     A               ; Z=0 OK.
  00D6    C9                            RET
                                        ;-------------------
  00D7    D5                    W00:    PUSH    DE
  00D8    E5                            PUSH    HL
  00D9    CD 0025               W0:     CALL SIOY
  00DC    0C                            INC C
  00DD    11 0000                       LD      DE,0000H        ; TIMEOUT
  00E0    3E 10                 W1:     LD      A,10H           ; SET SIO REG. FUER DCD, CTS
  00E2    ED 79                         OUT     (C),A
  00E4    CD 0064                       CALL    TX2             ; READ SIO REG. 0
  00E7    CB 5F                         BIT     3,A             ; DCD
  00E9    20 28                         JR      NZ,W3           ; -> DRUCKER ONLINE
  00EB    1D                            DEC     E
  00EC    20 F2                         JR      NZ,W1
  00EE    15                            DEC     D
  00EF    20 EF                         JR      NZ,W1
  00F1    CD 0097                       CALL PKEY
  00F4    28 E3                         JR Z,W0                 ; KEINE TASTE
  00F6    CD 006B                       CALL INP0               ; ZEICHEN READ
  00F9    FE 1B                         CP 1BH                  ; ESC
  00FB    20 DC                         JR NZ,W0
  00FD    21 0116                       LD HL,ERRTEX
  0100    5E                    W4:     LD E,(HL)
  0101    7B                            LD A,E
  0102    FE FF                         CP 0FFH
  0104    28 06                         JR Z,W5
  0106    CD 004C                       CALL OUT0
  0109    23                            INC HL
  010A    18 F4                         JR W4
                                        ;------------
  010C    E1                            W5:     POP     HL
  010D    D1                            POP     DE
  010E    C1                            POP     BC
  010F    3E 01                         LD A,01
  0111    3C                            INC A           ; Z=1
  0112    C9                            RET
                                        ;-----------
  0113    E1                            W3:     POP HL
  0114    D1                            POP DE
  0115    C9                            RET             ; ZEICHEN AUSGEBEN
                                        ;------------
                                
  0116    0A 0D 07 07           ERRTEX: DEFB    0AH,0DH,7,7,7           ; CR,LF,BELL
  011A    07                    
  011B    44 72 75 63                   DEFM    'Drucker nicht bereit oder Fehler!'
  011F    6B 65 72 20           
  0123    6E 69 63 68           
        MACRO-80 3.43   27-Jul-81       PAGE    1-7


  0127    74 20 62 65           
  012B    72 65 69 74           
  012F    20 6F 64 65           
  0133    72 20 46 65           
  0137    68 6C 65 72           
  013B    21                    
  013C    0A 0D 07 07                   DEFB    0AH,0DH,7,7,7,0FFH,0FFH
  0140    07 FF FF              
                                
  0143    C5                    PLISTST: PUSH    BC
  0144    CD 0025                       CALL SIOY
  0147    0C                            INC C
  0148    3E 10                         LD A,10H        ; SIO HANDSHAKE RESET DCD, CTS
  014A    ED 79                         OUT (C),A
  014C    CD 0064                       CALL TX2
  014F    0E 00                         LD      C,0
  0151    CB 5F                         BIT     3,A
  0153    28 04                         JR      Z,NOT
  0155    3E FF                         LD      A,0FFH
  0157    C1                            POP     BC
  0158    C9                            RET
                                
  0159    AF                    NOT:    XOR     A
  015A    C1                            POP     BC
  015B    C9                            RET
                                
                                ;---------------------------------
                                ; PIO INIT PORT A
                                ; PA0,BAI1,RT,/RFDC,RSCS,TA16,LATCH,QA7
                                ; PIO INIT PORT B
                                ; PCU,U1,U2,U3,U4,U5,ND, (NC)
                                
  015C    31 B000               LOS:    LD SP,0B000H
  015F    ED 5E                         IM 2
                                        ;---------------
                                        ; PORT A
  0161    3E 0F                         LD      A,0FH           ; MODE 0 ALS AUSGANG
  0163    D3 1D                         OUT     (PIOA+1),A
  0165    3E 07                         LD      A,07H           ; KEIN INTERRUPT
  0167    D3 1D                         OUT     (PIOA+1),A
  0169    AF                            XOR     A
  016A    D3 1C                         OUT     (PIOA),A        ; PIOA = 00H, EPROM ON
                                
                                        ; PORT B
  016C    3E 0F                         LD      A,0FH           ; MODE 0 ALS AUSGANG
  016E    D3 1F                         OUT     (PIOB+1),A
  0170    3E 07                         LD      A,07H           ; KEIN INTERRUPT
  0172    D3 1F                         OUT     (PIOB+1),A
  0174    3E 3F                         LD      A,3FH           ; FUER UHR SRAM
  0176    D3 1E                         OUT     (PIOB),A        ; PIOB =00H
                                        ;---------------
                                        ; INTERRUPT COUNTER
                                        ;
  0178    3E 15                         LD      A,MSTIME        ; SET INT INTERVAL H<-> L
  017A    D3 97                         OUT     (URCS+17H),A
  017C    AF                            XOR     A
        MACRO-80 3.43   27-Jul-81       PAGE    1-8


  017D    D3 1E                         OUT     (PIOB),A        ;  PIO B =00H
                                
                                ;-------------------------------
                                ; NOCH IM EPROM
                                ;   EPROM NACH SRAM BANK0 KOPIEREN 1:1
                                
  017F    21 0000                       LD HL,0000H             ; PROG.ADR. QUELLE EPROM
  0182    11 0000                       LD DE,0000H             ; ZIEL RAM
  0185    01 8000                       LD BC,08000H            ; PROG. L[NGE 32K
  0188    ED B0                         LDIR                    ; ]BERTRGEN IN RAM BANK0
                                
                                        ;-------------------
  018A    DB 1C                         IN A,(PIOA)
  018C    CB C7                         SET TAS,A
  018E    D3 1C                         OUT (PIOA),A            ; SET SRAM WR=BANK1
                                
                                ;   EPROM NACH SRAM BANK1 KOPIEREN 1:1
  0190    21 0000                       LD HL,0000H             ; PROG.ADR. QUELLE EPROM
  0193    11 0000                       LD DE,0000H             ; ZIEL RAM
  0196    01 8000                       LD BC,08000H            ; PROG. L[NGE 32K
  0199    ED B0                         LDIR                    ; ]BERTRGEN IN RAM BANK1
                                
                                ;-------------------------------
                                ;   EPROM AUSSCHALTEN , AB HIER IM RAM
                                
  019B    3E 40                         LD A,EOFF       ; EPROM OFF
  019D    D3 1C                         OUT (PIOA),A          
                                
                                ;***************
                                ; AB HIER IM SRAM
                                ;---------------------
                                ; CTC0 INIT :16=6,51us
                                ; 1er TEILER FUER SIOA,SIOB
                                
  019F    3E 47                         LD A,BAUD1
  01A1    D3 10                         OUT (CTC0),A
  01A3    3E 04                         LD A,TIME1
  01A5    D3 10                         OUT (CTC0),A
                                
                                ;----------------------
                                ; LCD SET
                                
  01A7    3E 80                 LCDS:   LD A,80H        ; COMMAND MODE=OR-MODE & INTERNAL
  01A9    CD 02D5                       CALL LCD1       ; COMMAND MODE=OR-MODE & INTERNAL CG-ROM
                                
                                        ; GRAPHIC HOME ADRESSE
  01AC    3E 00                         LD A,00H
  01AE    CD 02D1                       CALL LCD0
  01B1    3E 00                         LD A,00H
  01B3    CD 02D1                       CALL LCD0
                                
                                        ; GRAPHIC HOME AREA
  01B6    3E 42                         LD A,42H
  01B8    CD 02D5                       CALL LCD1
  01BB    3E 1E                         LD A,1EH
  01BD    CD 02D1                       CALL LCD0
        MACRO-80 3.43   27-Jul-81       PAGE    1-9


  01C0    3E 00                         LD A,00H
  01C2    CD 02D1                       CALL LCD0
                                
                                        ; TEXT HOME ADRESSE
  01C5    3E 43                         LD A,43H
  01C7    CD 02D5                       CALL LCD1
  01CA    3E 00                         LD A,00H
  01CC    CD 02D1                       CALL LCD0
  01CF    3E 0F                         LD A,0FH
  01D1    CD 02D1                       CALL LCD0
                                
                                        ; TEXT AREA
  01D4    3E 40                         LD A,40H
  01D6    CD 02D5                       CALL LCD1
  01D9    3E 1E                         LD A,1EH
  01DB    CD 02D1                       CALL LCD0
  01DE    3E 00                         LD A,00H
  01E0    CD 02D1                       CALL LCD0
                                
  01E3    3E 41                         LD A,41H
  01E5    CD 02D5                       CALL LCD1
                                
  01E8    3E 94                         LD A,94H
  01EA    CD 02D5                       CALL LCD1
                                 
                                ;---------------------
                                ; WATCHDOG INIT
                                
  01ED    3E DB                         LD A,0DBH       ; TC=2^22
                                ;       OUT (WDTCR),A
  01EF    3E FB                         LD A,0FBH
                                ;       OUT (WDTER),A
                                ;---------------------
  01F1                          SIOS:
