                                ;-------------------------------
                                ; ### IDE ROUTINES ###
                                ;-------------------------------
                                ; SET SEKTOR COUNT AND LBA REGISTER OF THE DRIVE.
                                ; REGISTER BC = TRACK AND DE=SECTOR  CONTAIN THE SECTOR ADDRESS
                                ; (LBA 3, 2, 1 AND 0).
                                
  FB97                          IDE_SET_LBA:
  FB97    DB FF                         IN A,(IDESTAT)
  FB99    17                            RLA
  FB9A    38 FB                         JR C,IDE_SET_LBA
                                        ;-------
  FB9C    F5                            PUSH AF
  FB9D    18 05                         JR IDE_SET01
  FB9F    3E 49                         LD A,'I'
  FBA1    CD F92C                       CALL GROUP
                                
  FBA4                          IDE_SET01:
  FBA4    3E 01                         LD A,1
  FBA6    D3 FA                         OUT (IDESCNT),A
  FBA8    78                            LD A,B
  FBA9    D3 FD                         OUT (IDECHI),A          ; TRACK HIGH
  FBAB    79                            LD A,C
  FBAC    D3 FC                         OUT (IDECLO),A          ; TRACK LOW
  FBAE    7B                            LD A,E
  FBAF    D3 FB                         OUT (IDESNUM),A         ; SECTOR
                                ;       LD A,D
                                ;       AND 0FH
                                ;       LD D,A
  FBB1    3A FFAD                       LD A,(DRIVE)
  FBB4    E6 0F                         AND 0FH         ; HS0 - HS3 SELECT
  FBB6    3D                            DEC A
                                ;       OR D            ; LBA + HEAD
  FBB7    57                            LD D,A          ; 4BIT LOW
  FBB8    3A FFAD                       LD A,(DRIVE)
  FBBB    E6 F0                         AND 0F0H        ; LBA, SLAVE/MASTER
  FBBD    B2                            OR D            ; 4BIT HIGH
  FBBE    CB FF                         SET 7,A
  FBC0    D3 FE                         OUT (IDESDH),A
  FBC2    F1                            POP AF
  FBC3    C9                            RET
                                ;------------------------------
                                ; WAIT READY FOR DATA
                                ; BIT 3 IS SET WHEN IT IS
                                
  FBC4                          WAITDRQ:
  FBC4    0E C8                         LD C,200
  FBC6    06 C8                         LD B,200
  FBC8    AF                            XOR A           ; CARRY  C= 0
        MACRO-80 3.43   27-Jul-81       PAGE    1-32


  FBC9    DB FF                 WAITDR1:IN A,(IDECMD)
  FBCB    CB 5F                         BIT 3,A
  FBCD    C0                            RET NZ          ;,WAITEND
                                ;
                                ;
  FBCE    10 F9                         DJNZ WAITDR1
  FBD0    0D                            DEC C
  FBD1    20 F6                         JR NZ,WAITDR1
  FBD3    37                            SCF             ; CARRY C=1
  FBD4    C9                            RET
                                ;------------------------------
                                ; WAIT FOR THE CONTROLLER TO NOT BE BUSY WITH A COMMAND
                                ; IF BIT 7 IS SET, THE CONTROLLER IS BUSY
                                
  FBD5                          WAITBSY:
  FBD5    0E C8                         LD C,200        ; DELAY VALUE FOR MILISECONDS
  FBD7    06 C8                         LD B,200                ; TENTHS OF SECONDS
  FBD9    DB FF                         WAITBS1:IN A,(IDECMD)
  FBDB    CB 7F                         BIT 7,A         ; BUSY BIT SET
  FBDD    C8                            RET Z           ; NOT BUSY -> JUMP ON OUT
  FBDE    10 F9                         DJNZ WAITBS1
  FBE0    0D                            DEC C
  FBE1    20 F6                         JR NZ,WAITBS1
  FBE3    0C                            INC C           ; Z=1
  FBE4    C9                            RET
                                ;------------------------------
                                ; WAIT FOR THE CONTROLLER TO BE RADY FOR A COMMAND
                                ; BIT 6 IS SET WHEN THE DRIVE IS READY
                                
  FBE5    CD FBD5               WAITRDY:CALL WAITBSY
  FBE8    20 0F                         JR NZ,WAITERR
  FBEA    0E C8                         LD C,200        ;DELAY VALUE FOR MILISECONDS
  FBEC    06 C8                         LD B,200                ; TENTHS OF SECONDS
  FBEE    DB FF                 WAITRD1:IN A,(IDECMD)
  FBF0    CB 77                         BIT 6,A
  FBF2    20 0B                         JR NZ,WAITEND
  FBF4    10 F8                         DJNZ WAITRD1
  FBF6    0D                            DEC C
  FBF7    20 F5                         JR NZ,WAITRD1
                                        ;------------
  FBF9                          WAITERR:
